# 3. Get DEG of a certain list
```{r, message= FALSE}
load(file = "Troponin_beforeDE_Salmon.Rdata")
load(file = "Troponin_DeSeq2_CasevsControl_Salmon.RData")
GeneOI <- c("TNNI1","TNNI2","TNNI3","TNNT1","TNNT2","TNNT3")
DEGSubset <- DEG_DEseq2[DEG_DEseq2$SYMBOL %in% GeneOI, ]# Subset expression data
ENSEMBL_OI <- DEGSubset$ENSEMBL_ori
exprSubset <- combat_transformed_data[rownames(combat_transformed_data) %in% ENSEMBL_OI, ]
exprSubset <- as.data.frame(exprSubset)
rownames(exprSubset) <- ifelse(
  is.na(match(rownames(exprSubset), DEGSubset$ENSEMBL_ori)),
  rownames(exprSubset),
  DEGSubset$SYMBOL[match(rownames(exprSubset), DEGSubset$ENSEMBL_ori)]
)


# --- 1. Melt expression data to long format ---
df_long <- reshape2::melt(as.matrix(exprSubset), 
                          varnames = c("Gene", "Sample"), 
                          value.name = "Expression")

# Add group info
df_long$Group <- pData[df_long$Sample, "mnd"]

# --- 2. Prepare annotation table ---
# Create fold change / p-value label
DEGSubset$label <- paste0("log2(Case/Control)=", round(DEGSubset$log2FoldChange, 2), 
                      "\npadj=", signif(DEGSubset$padj, 3))

# Compute annotation positions above each gene facet
annotation <- df_long %>%
  group_by(Gene) %>%
  summarise(y_pos = max(Expression) * 1.05) %>%  # position above dots
  left_join(DEGSubset, by = c("Gene" = "SYMBOL"))

# --- 3. Dotplot with error bars and annotations ---
dotplot <- ggplot(df_long, aes(x = Group, y = Expression, color = Group)) +
  # Jittered dots
  geom_point(position = position_jitter(width = 0.2), size = 2, alpha = 0.7) +
  # Error bars for mean ± SD
  stat_summary(fun.data = mean_sdl, fun.args = list(mult = 1),  # SD; use mult=1.96 for 95% CI
               geom = "errorbar", width = 0.2, aes(color = Group)) +
  # Optional: add a mean point
  stat_summary(fun = mean, geom = "crossbar",  width = 0.4, aes(color = Group)) +
  # Annotation for fold change / p-value
  geom_text(data = annotation, aes(x = 1.5, y = y_pos, label = label), 
            inherit.aes = FALSE, hjust = 0.5, size = 2.5) +
  facet_wrap(~ Gene, scales = "free_y") +
  theme_bw() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1),plot.title = element_text(hjust = 0.5) ) +
  labs(title = "Troponin isotype gene expression (Salmon counts)",
       y = "Batch-corrected VST expression",
       x = "Group")

ggsave(dotplot, filename = "Troponin_Salmon_isotypes.tiff",width =6,height =8)
write.csv(DEGSubset,"Troponin_Salmon_isotypes.csv",quote = F)#  
  
```
