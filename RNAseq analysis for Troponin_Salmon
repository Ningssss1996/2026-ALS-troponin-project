#----2.1 DeSeq2 analysis----
```{r, message= FALSE}
load(file = "Troponin_beforeDE_Salmon.Rdata")
library(apeglm)

# Step 1: Create DESeq2 object
dds <- DESeqDataSetFromMatrix(countData = exprSet,
                              colData = sample_anno,
                              design = ~ sex + mnd)
dds$mnd <- relevel(dds$mnd, ref = "Control")   #designate control group
keep <- rowSums(counts(dds) >= 10) >=  17
dds <- dds[keep,]

# Step 2: Run DESeq
dds <- DESeq(dds)
res <- results(dds,contrast=c("mnd", "Case","Control"))  #result as ALS/CTL
res <- lfcShrink(dds, coef="mnd_Case_vs_Control", type="apeglm")
resOrdered <- res[order(res$padj),] 
tempDEG <- as.data.frame(resOrdered)
DEG_DEseq2 <- na.omit(tempDEG)

#find the matched ENSEMBL
DEG_DEseq2$ENSEMBL_ori <- rownames(DEG_DEseq2)  # temporarily store original IDs
DEG_DEseq2$ENSEMBL <- gsub("\\.\\d+$", "", rownames(DEG_DEseq2))
gene_map <- AnnotationDbi::select(
    org.Hs.eg.db,
    keys = DEG_DEseq2$ENSEMBL,
    columns = c("SYMBOL"),
    keytype = "ENSEMBL"
)

# Add SYMBOL as rownames
DEG_DEseq2 <- DEG_DEseq2 %>%
  as.data.frame() %>%
  left_join(gene_map, by = c("ENSEMBL" = "ENSEMBL"))   #Add gene symbol

# Step 3: Transform for visualization or batch correction
vsd <- vst(dds, blind=T)#DESeq2_normalization   use vst because the sample size is large
dat <- as.data.frame(assay(vsd))  
plotPCA(vsd, intgroup = "sex")
plotPCA(vsd, intgroup = "replicate_batch")
plotPCA(vsd, intgroup = "mnd")
plotPCA(vsd, intgroup = "age")

# Step 4: Apply ComBat if needed
combat_transformed_data <- ComBat(dat = dat,  #This is only used for visualization
                      batch = sample_anno$sex,      #Remove batch effect
                      mod = model.matrix(~ mnd, data =colData(vsd) ))  # preserve group differences

save(dds, res, vsd, dat, DEG_DEseq2,combat_transformed_data, file = "Troponin_DeSeq2_CasevsControl_Salmon.RData")
write.csv(DEG_DEseq2,file = 'Troponin_DeSeq2_CasevsControl.csv')
rm(list=ls())
```
   
